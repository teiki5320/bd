# Port du serveur local
PORT=4600

# Fournisseur d'images :
#   openart      → ton compte OpenArt via le MCP officiel (meilleure qualité + visages constants).
#                  Prérequis : claude mcp add --transport http --scope user openart https://mcp.openart.ai/mcp
#                  puis authentification une fois via `claude` → /mcp → openart.
#   pollinations → gratuit, sans compte (par défaut)
#   fal          → fal.ai FLUX (clé requise)
#   manual       → aucune génération auto, import à la main
IMAGE_PROVIDER=pollinations

# Nom du serveur MCP OpenArt si différent de "openart" (voir `claude mcp list`)
# OPENART_MCP_NAME=openart

# Clé fal.ai (uniquement si IMAGE_PROVIDER=fal) — https://fal.ai/dashboard/keys
FAL_KEY=
# Modèle fal.ai (optionnel, défaut : fal-ai/flux/dev)
# FAL_MODEL=fal-ai/flux/dev

# Chemin d'un Chromium/Chrome spécifique pour le rendu Remotion (optionnel)
# REMOTION_BROWSER_EXECUTABLE=
