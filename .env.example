# Port du serveur local
PORT=4600

# Fournisseur d'images : pollinations (gratuit, par défaut) | fal (clé requise) | manual (OpenArt à la main)
IMAGE_PROVIDER=pollinations

# Clé fal.ai (uniquement si IMAGE_PROVIDER=fal) — https://fal.ai/dashboard/keys
FAL_KEY=

# Chemin d'un Chromium/Chrome spécifique pour le rendu Remotion (optionnel)
# REMOTION_BROWSER_EXECUTABLE=
