{
  "name": "drama-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Studio local de micro-dramas africains : script par Claude, images IA, voix TTS, montage Remotion.",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:front\"",
    "dev:server": "node server/index.js",
    "dev:front": "vite",
    "build": "vite build",
    "start": "npm run build && node server/index.js"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.290",
    "@remotion/player": "^4.0.290",
    "@remotion/renderer": "^4.0.290",
    "@remotion/transitions": "^4.0.290",
    "express": "^4.21.2",
    "https-proxy-agent": "^9.1.0",
    "msedge-tts": "^1.3.4",
    "music-metadata": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.290"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^5.4.11"
  }
}
